<Window x:Class="HairCare.OperationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:HairCare"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Title="Оберіть операцію" Height="120" Width="240">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Margin="0,10" TextAlignment="Center" FontWeight="Bold">Оберіть операцію над записом</TextBlock>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Click="OnSelectClick" Margin="5" FontSize="14">Переглянути</Button>
            <Button Click="OnCompareClick" Margin="5" FontSize="14">Порівняти</Button>
        </StackPanel>
    </StackPanel>
</Window>
