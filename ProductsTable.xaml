<Window x:Class="HairCare.ProductsTable"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:HairCare"
      xmlns:collections="clr-namespace:System.Collections;assembly=mscorlib"
      mc:Ignorable="d"
      Title="Порівняння засобів догляду за волоссям" d:DesignHeight="350" d:DesignWidth="800">
    
    <Window.Resources>
        <local:TreeViewLineConverter x:Key="LineConverter"/>
        <Style x:Key="{x:Type TreeViewItem}" TargetType="{x:Type TreeViewItem}">
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="1,0,0,0"/>
            <Setter Property="IsSelected" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition MinWidth="19" Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            
                            <Rectangle x:Name="HorLn" Margin="9,1,0,0" Height="3" Fill="LightGray" SnapsToDevicePixels="True"/>
                            <Rectangle x:Name="VerLn" Width="3" Margin="0,0,1,0" Grid.RowSpan="2" SnapsToDevicePixels="true" Fill="LightGray"/>
                            
                            <Border Margin="0,5,0,0" Name="Bd" Grid.Column="1" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" MinWidth="20"/>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Converter={StaticResource LineConverter}}" Value="true">
                                <Setter TargetName="VerLn" Property="Height" Value="16"/>
                                <Setter TargetName="VerLn" Property="VerticalAlignment" Value="Top"/>
                            </DataTrigger>
                            <Trigger Property="IsExpanded" Value="false">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="HasHeader" Value="false"/>
                                    <Condition Property="Width" Value="Auto"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PART_Header" Property="MinWidth" Value="75"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="HasHeader" Value="false"/>
                                    <Condition Property="Height" Value="Auto"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PART_Header" Property="MinHeight" Value="19"/>
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Background="Lavender">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="0"  Grid.Row="0">
            <StackPanel >
                <Label Name="SelectViewState" Content="Перегляд" Background="WhiteSmoke" BorderBrush="Gray" BorderThickness="1"/>

                <ItemsControl Name="SelectProductView">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock Text="{Binding Path = StatName}" Margin="5" TextAlignment="Left"/>
                                <TextBox TextWrapping="Wrap" Name="SelectProductViewTextBox" Margin="5" Text="{Binding Path = StatValue, UpdateSourceTrigger = Explicit}"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <Button Content="Зберегти" Click="OnSaveSelectButtonClicked" Margin="5"/>
                <Button Content="Відмінити" Click="OnCancelSelectButtonClicked" Margin="5"/>
            </StackPanel>
        </ScrollViewer>
        
        <Grid Grid.Column="0" Name="SelectProductHidBox" >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            
            <Label Grid.Row="0" Content="Ієрархічна схема засобів догляду" Background="WhiteSmoke" BorderBrush="Gray" BorderThickness="1"/>
            <TreeView Name="HierarchicalScheme" Grid.Row="1">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Path=Nodes}">
                        <TextBlock Text="{Binding Name}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

            
            <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1"  Grid.Row="0">
                <StackPanel >
                <Label Content="Порівняння" Background="WhiteSmoke" BorderBrush="Gray" BorderThickness="1"/>
                <ItemsControl Name="CompareProductView">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock Text="{Binding Path = StatName}" Margin="5" TextAlignment="Left"/>
                                <TextBox TextWrapping="Wrap" IsReadOnly="True" Margin="5" Text="{Binding Path = StatValue}"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                    
                <Button Content="Повернутися до списку" Click="OnCancelCompareButtonClicked" Margin="5"/>
                </StackPanel>
            </ScrollViewer>
            
            <Grid Name="CompareProductHidBox" Grid.Column="1" >
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <ListView Name="ProductList" Grid.Row="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnProductListElementClicked" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=Function.StatValue}">Призначення</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=Brand.StatValue}">Бренд</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=PackagingVolume.StatValue}">Об'єм пакування</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=DispenserType.StatValue}">Тип дозатора</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=HairType.StatValue}">Тип волосся</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=TargetAudience.StatValue}">Цільова аудиторія</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=SeriesYear.StatValue}">Рік серії</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=Color.StatValue}">Аромат</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=Model.StatValue}">Лінійка</GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Path=Price}">Ціна, ₴</GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
                <StackPanel Grid.Row="1">
                    <Button Click="OnFindProductClicked" Content="Пошук" Name="FindButton"/>
                    <Button Click="OnCreateProductClicked" Content="Додати запис" />
                    <Button Name="SortingButton" Click="OnSortClicked" Content="Сортувати" />
                    <Button Click="OnDeleteRecordClicked" Content="Видалити запис" />
                </StackPanel>
            </Grid>
        </Grid>
</Window>
