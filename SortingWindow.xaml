<Window x:Class="HairCare.SortingWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:local="clr-namespace:HairCare"

        mc:Ignorable="d"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterOwner"

        Title="Сортування" Padding="10" Width="200" Height="500">

    

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <TextBlock Margin="0,10" TextAlignment="Center" FontWeight="Bold">Оберіть поле для сортування</TextBlock>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">

            <CheckBox Name="Reverse"  Margin="5" FontSize="12">Сортувати за спаданням</CheckBox>

            <Button Click="OnSortByFunction" Margin="5" FontSize="14">Призначення</Button>

            <Button Click="OnSortByBrand" Margin="5" FontSize="14">Бренд</Button>

            <Button Click="OnSortByPackagingVolume" Margin="5" FontSize="14">Об'єм пакування</Button>

            <Button Click="OnSortByDispenserType" Margin="5" FontSize="14">Тип дозатора</Button>

            <Button Click="OnSortByHairType" Margin="5" FontSize="14">Тип волосся</Button>

            <Button Click="OnSortByTargetAudience" Margin="5" FontSize="14">Цільова аудиторія</Button>

            <Button Click="OnSortBySeriesYear" Margin="5" FontSize="14">Рік серії</Button>

            <Button Click="OnSortByColor" Margin="5" FontSize="14">Аромат</Button>

            <Button Click="OnSortByModel" Margin="5" FontSize="14">Лінійка</Button>

            <Button Click="OnSortByPrice" Margin="5" FontSize="14">Ціна, ₴</Button>

        </StackPanel>

    </StackPanel>

</Window>

