<Window x:Class="HairCare.CreateProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:HairCare"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Title="Оберіть тип засобу" Height="120" Width="600">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Margin="0,10" TextAlignment="Center" FontWeight="Bold">Який засіб бажаєте додати?</TextBlock>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Click="CreateBalance" Margin="5" FontSize="14">Кондиціонер</Button>
            <Button Click="CreateCity" Margin="5" FontSize="14">Маска</Button>
            <Button Click="CreateFolding" Margin="5" FontSize="14">Олійка</Button>
            <Button Click="CreateMountain" Margin="5" FontSize="14">Термозахист</Button>
            <Button Click="CreateShampoo" Margin="5" FontSize="14">Шампунь</Button>
        </StackPanel>
    </StackPanel>
</Window>